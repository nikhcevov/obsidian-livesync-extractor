baseURL = "${SITE_BASE_URL}"
title = "${SITE_TITLE}"
languageCode = "${SITE_LANGUAGE}"
theme = "PaperMod"
enableRobotsTXT = true
enableGitInfo = false

[pagination]
  pagerSize = 10

[outputs]
  home = ["HTML", "RSS"]
  section = ["HTML", "RSS"]

[taxonomies]
  tag = "tags"
  category = "categories"

[permalinks]
  posts = "${PERMALINK_PATTERN}"

[params]
  env = "production"
  ShowReadingTime = true
  ShowShareButtons = true
  ShowCodeCopyButtons = true
  ShowToc = true
  disableSpecial1stPost = false
  disableScrollToTop = false
  comments = false
  hidemeta = false
  hideSummary = false
  showtoc = true
  tocopen = false

[sitemap]
  changefreq = "weekly"
  priority = 0.5
  filename = "sitemap.xml"

[markup]
  [markup.goldmark]
    [markup.goldmark.renderer]
      unsafe = true
